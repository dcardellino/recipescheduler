# --- Database (Supabase Postgres) ---
# On Vercel, the Supabase integration provides POSTGRES_URL (pooled) and
# POSTGRES_URL_NON_POOLING (direct) automatically — the app falls back to those,
# so DATABASE_URL/DIRECT_URL only need to be set for local dev or non-Vercel envs.
# Runtime connection: Supabase Transaction Pooler (Supavisor), port 6543.
DATABASE_URL="postgres://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres"
# Direct connection, port 5432 — used only by drizzle-kit for migrations.
DIRECT_URL="postgres://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres"

# --- Supabase Auth / API ---
NEXT_PUBLIC_SUPABASE_URL="https://<project-ref>.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="<anon-key>"
# Server-only: sends sign-in OTPs and writes to Storage. Never expose to the client.
SUPABASE_SERVICE_ROLE_KEY="<service-role-key>"

# --- App ---
# Public base URL. In production set to the deployed URL (e.g. https://recipes.example.com).
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
# HS256 secret for signed household invite tokens (e.g. `openssl rand -hex 32`).
INVITE_TOKEN_SECRET="<random-32-byte-hex>"

# --- Storage ---
# Public Supabase Storage bucket for recipe images.
RECIPE_IMAGE_BUCKET="recipe-images"

# --- Email (household invites via Resend) ---
# Auth is email + password (no sign-in email is sent). Resend is used only for
# the app's household invite emails.
RESEND_API_KEY="re_..."
MAIL_FROM="RecipeScheduler <recipes@example.com>"
